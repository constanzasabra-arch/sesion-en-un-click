        // Mostrar modal de opciones de envío
        mostrarModalEnvioPortal(pac.nombre, codigo, msg, tel, email);
    }).catch(()=>{
        mostrarModalEnvioPortal(pac.nombre, codigo, msg, tel, email);
    });
}

function mostrarModalEnvioPortal(nombre, codigo, msg, tel, email) {
    var overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;inset:0;background:rgba(44,48,64,.5);z-index:2000;display:flex;align-items:flex-end;justify-content:center;padding:16px;';
    var waBtn = tel ? '<button onclick="window.open(\'https://wa.me/'+tel+'?text=\'+encodeURIComponent(\'' + msg.replace(/'/g,"\'") + '\'),\'_blank\')" style="background:#dcfce7;color:#16a34a;border:none;border-radius:12px;padding:12px;font-family:\'DM Sans\',sans-serif;font-size:.85rem;font-weight:700;cursor:pointer;">💬 WhatsApp</button>' : '<div></div>';
    var emBtn = email ? '<button onclick="window.open(\'mailto:'+email+'?subject=Portal+Familias&body=\'+encodeURIComponent(\''+msg.replace(/'/g,"\'")+'\')\')" style="background:var(--sky-p);color:#0d6b8a;border:none;border-radius:12px;padding:12px;font-family:\'DM Sans\',sans-serif;font-size:.85rem;font-weight:700;cursor:pointer;">📧 Email</button>' : '<div></div>';
    overlay.innerHTML = '<div style="background:white;border-radius:24px 24px 16px 16px;padding:24px;width:100%;max-width:480px;box-shadow:0 -8px 40px rgba(44,48,64,.2);">' +
        '<div style="font-family:\'Nunito\',sans-serif;font-size:1.1rem;font-weight:900;color:var(--sky);margin-bottom:4px;">🏡 Invitar a ' + nombre + '</div>' +
        '<div style="font-size:.78rem;color:var(--ink-60);margin-bottom:16px;">Código: <strong style="color:var(--lilac);font-size:1rem;letter-spacing:2px;">' + codigo + '</strong> · Mensaje copiado ✅</div>' +
        '<div style="background:var(--sky-p);border-radius:12px;padding:12px;margin-bottom:16px;font-size:.82rem;color:var(--ink);line-height:1.6;max-height:120px;overflow-y:auto;">' + msg.split('\n').join('<br>') + '</div>' +
        '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;">' + waBtn + emBtn + '</div>' +
        '<div style="text-align:center;font-size:.75rem;color:var(--ink-30);margin-bottom:12px;">El mensaje ya está copiado. Pégalo donde quieras.</div>' +
        '<button onclick="this.closest(\'[style*=fixed]\').remove()" style="width:100%;padding:12px;background:#fee2e2;color:#dc2626;border:none;border-radius:12px;font-family:\'DM Sans\',sans-serif;font-size:.85rem;font-weight:700;cursor:pointer;">Cerrar</button>' +
        '</div>';
    document.body.appendChild(overlay);
    overlay.addEventListener('click', function(e) { if(e.target===overlay) overlay.remove(); });
}

// ASHA
async function cargarASHA() {
    const cont = document.getElementById('asha-lista');
    if (!cont) return;
    try {
        const { data, error } = await sb.from('asha_articulos').select('*').order('creado', {ascending:false}).limit(20);
        if (error || !data || !data.length) {
            cont.innerHTML = '<div class="empty"><div class="ei">📚</div><p>No hay artículos aún.<br><small style="color:var(--ink-30)">Agrega artículos en la tabla asha_articulos de Supabase.</small></p></div>';
            return;
        }
        cont.innerHTML = data.map(a => `
            <div style="border:1.5px solid rgba(44,48,64,.08);border-radius:14px;padding:14px;margin-bottom:10px;background:#fafcff;">
                <div style="font-size:.7rem;font-weight:700;color:var(--sky);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;">${a.categoria||'ASHA'} · ${new Date(a.creado).toLocaleDateString('es-CL')}</div>
                <div style="font-size:.95rem;font-weight:700;color:var(--ink);margin-bottom:6px;">${a.titulo}</div>
                <div style="font-size:.82rem;color:var(--ink-60);line-height:1.6;margin-bottom:10px;">${a.resumen||''}</div>
                ${a.url?`<a href="${a.url}" target="_blank" style="font-size:.78rem;color:var(--sky);font-weight:600;">Leer artículo →</a>`:''}
            </div>
        `).join('');
    } catch(e) {
        cont.innerHTML = '<div class="empty"><div class="ei">📚</div><p>Crea la tabla asha_articulos en Supabase para usar esta sección.</p></div>';
    }
}

// UTILS
function calcEdad(fec) {
    const hoy=new Date(), nac=new Date(fec); let a=hoy.getFullYear()-nac.getFullYear();
    const m=hoy.getMonth()-nac.getMonth(); if(m<0||(m===0&&hoy.getDate()<nac.getDate())) a--;
    return a+' años';
}

// ── ANAMNESIS ──
function toggleAnamnesis() {
    const body=document.getElementById('ana-body');
    const arrow=document.getElementById('ana-arrow');
    const hint=document.getElementById('werni-ana-hint');
    body.classList.toggle('open');
    arrow.classList.toggle('open');
    if(body.classList.contains('open')) hint.classList.add('show');
    else hint.classList.remove('show');
}

function getRadioVal(name) {
    const el=document.querySelector('input[name="'+name+'"]:checked');
    return el ? el.value : '';
}

function getAnamnesisData() {
    return {
        parto: document.getElementById('ana-parto').value,
        gest: document.getElementById('ana-gest').value,
        peri_obs: document.getElementById('ana-peri-obs').value,
        marcha: document.getElementById('ana-marcha').value,
        hipotonia: getRadioVal('ana-hip'),
        gateo: getRadioVal('ana-gateo'),
        primeras_palabras: document.getElementById('ana-pp').value,
        frases: document.getElementById('ana-frases').value,
        comprension: getRadioVal('ana-comp'),
        intel: document.getElementById('ana-intel').value,
        juego: getRadioVal('ana-juego'),
        respiracion: getRadioVal('ana-resp'),
        mordida: document.getElementById('ana-mordida').value,
        reposo_lingual: document.getElementById('ana-lengua').value,
        alimentacion: document.getElementById('ana-ali').value,
        audicion: document.getElementById('ana-audio').value,
        fam_antec: getRadioVal('ana-fam'),
        motivo: document.getElementById('ana-motivo').value
    };
}

function resetAnamnesis() {
    ['ana-parto','ana-gest','ana-marcha','ana-pp','ana-frases','ana-intel','ana-mordida','ana-lengua','ana-ali','ana-audio'].forEach(id=>{
        const el=document.getElementById(id); if(el) el.value='';
    });
    ['ana-peri-obs','ana-motivo'].forEach(id=>{
        const el=document.getElementById(id); if(el) el.value='';
    });
    document.querySelectorAll('.achip input').forEach(el=>el.checked=false);
    document.getElementById('ana-body').classList.remove('open');
    document.getElementById('ana-arrow').classList.remove('open');
    document.getElementById('werni-ana-hint').classList.remove('show');
}
</script>
