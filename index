<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sesión en un Click · Fono Aprende</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --sky:#89C4D9;--sky-l:#C8E4F0;--sky-p:#EDF6FA;
  --lilac:#B8A0CC;--lilac-l:#DDD0EE;--lilac-p:#F4F0FA;
  --rose:#D9A0B0;--rose-l:#EDD0D8;--rose-p:#FAF0F3;
  --sage:#9ABBA8;--sage-l:#C8DDD2;--sage-p:#EDF5F1;
  --ink:#2C3040;--ink-60:#7A7E90;--ink-30:#C0C2CC;
  --grad:linear-gradient(135deg,#C8E4F0 0%,#DDD0EE 60%,#FAF0F3 100%);
  --bg:linear-gradient(160deg,#EDF6FA 0%,#F4F0FA 50%,#FAF0F3 100%);
  --shadow:0 2px 16px rgba(44,48,64,.08);
  --shadow-lg:0 8px 40px rgba(44,48,64,.14);
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);min-height:100vh;color:var(--ink);}
.screen{display:none;}.screen.active{display:block;}

/* ── LOGIN ── */
.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background:linear-gradient(160deg,#e8f4fb 0%,#f0eaf8 50%,#faf0f5 100%);}
.login-card{background:white;border-radius:28px;padding:36px 32px 30px;width:100%;max-width:380px;box-shadow:0 12px 48px rgba(44,48,64,.12);position:relative;overflow:hidden;}
.login-card::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:var(--grad);}
.login-logo{text-align:center;margin-bottom:26px;}
.login-logo img{width:140px;height:auto;display:block;margin:0 auto 10px;}
.login-logo .sub{font-size:.75rem;color:var(--ink-30);margin-top:4px;font-family:'DM Sans',sans-serif;}
.login-logo .app-name{font-family:'Nunito',sans-serif;font-size:1.1rem;font-weight:800;color:var(--sky);}
.login-tabs{display:flex;background:#f4f6fb;border-radius:14px;padding:4px;margin-bottom:20px;gap:4px;}
.login-tab{flex:1;padding:9px;border:none;background:transparent;border-radius:11px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;color:var(--ink-30);cursor:pointer;transition:all .2s;}
.login-tab.active{background:white;color:var(--ink);font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.08);}
.fld{margin-bottom:14px;}
.fld label{display:block;font-size:11px;font-weight:700;color:var(--ink-60);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;}
.fld input{width:100%;padding:13px 15px;border:1.5px solid rgba(44,48,64,.12);border-radius:13px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--ink);background:#FAFCFF;outline:none;transition:all .2s;}
.fld input:focus{border-color:var(--sky);box-shadow:0 0 0 4px rgba(137,196,217,.15);}
.btn-enter{width:100%;padding:14px;background:var(--grad);color:white;border:none;border-radius:14px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:700;cursor:pointer;margin-top:6px;box-shadow:0 4px 18px rgba(137,196,217,.4);transition:all .2s;}
.btn-enter:hover{transform:translateY(-2px);}
.btn-enter:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.login-err{font-size:12px;color:#dc2626;text-align:center;margin-top:10px;min-height:16px;}
.login-ok{font-size:12px;color:#16a34a;text-align:center;margin-top:10px;min-height:16px;}

/* ── HEADER ── */
.app-header{background:var(--grad);padding:0;box-shadow:0 4px 20px rgba(184,224,246,.45);}
.app-header-inner{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:12px 16px;max-width:1100px;margin:0 auto;}
.h-left{display:flex;align-items:center;gap:8px;}
.h-center{text-align:center;}
.h-center .h-title{font-family:'Nunito',sans-serif;font-size:1.1rem;font-weight:900;color:#4A9AB8;}
.h-center .h-sub{font-size:.65rem;color:#5A6A78;margin-top:1px;font-weight:500;}
.h-right{display:flex;align-items:center;justify-content:flex-end;gap:8px;}
.header-pac{background:rgba(255,255,255,.65);border:1.5px solid rgba(255,255,255,.9);border-radius:20px;padding:6px 13px;font-size:.75rem;font-weight:600;color:var(--ink-60);cursor:pointer;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.save-pill{background:rgba(255,255,255,.7);border-radius:20px;padding:5px 11px;font-size:.68rem;font-weight:600;color:var(--ink-60);display:flex;align-items:center;gap:5px;white-space:nowrap;}
.save-dot{width:6px;height:6px;border-radius:50%;background:var(--ink-30);}
.save-dot.ok{background:#16a34a;}
.save-dot.saving{background:#f59e0b;animation:blink 1s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
.user-info{display:flex;align-items:center;gap:6px;}
.ubadge{font-size:.7rem;color:var(--ink-60);background:rgba(255,255,255,.6);border:1.5px solid rgba(255,255,255,.8);border-radius:20px;padding:5px 11px;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.btn-logout{background:rgba(255,255,255,.5);border:1.5px solid rgba(44,48,64,.12);border-radius:10px;padding:5px 11px;font-family:'DM Sans',sans-serif;font-size:.72rem;font-weight:600;color:var(--ink-60);cursor:pointer;transition:all .2s;}
.btn-logout:hover{background:var(--rose-p);color:var(--rose);border-color:var(--rose-l);}

/* ── TABS ── */
.main-tabs{background:white;border-bottom:1px solid rgba(44,48,64,.08);display:flex;justify-content:center;overflow-x:auto;scrollbar-width:none;}
.main-tabs::-webkit-scrollbar{display:none;}
.mtab{flex-shrink:0;padding:12px 18px;background:none;border:none;border-bottom:2.5px solid transparent;margin-bottom:-1px;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:600;color:var(--ink-30);cursor:pointer;transition:all .2s;}
.mtab.active{color:var(--sky);border-bottom-color:var(--sky);}

/* ── LAYOUT 2 COLS ── */
.app-body{display:grid;grid-template-columns:260px 1fr;max-width:1100px;margin:0 auto;gap:0;min-height:calc(100vh - 130px);}
.sidebar{border-right:1px solid rgba(44,48,64,.07);padding:16px;background:white;}
.sidebar-title{font-size:.7rem;font-weight:700;color:var(--ink-30);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;}
.main-content{padding:16px;}

/* ── CONTENIDO VISTAS ── */
.vista{display:none;}.vista.active{display:block;}
.card{background:white;border-radius:18px;padding:18px;margin-bottom:14px;box-shadow:var(--shadow);}
.card-title{font-family:'Nunito',sans-serif;font-size:1rem;font-weight:800;color:var(--sky);margin-bottom:14px;}
.fgroup{margin-bottom:14px;position:relative;}
.flabel{display:block;font-size:.75rem;font-weight:700;margin-bottom:6px;color:var(--sky);}
.finput,.ftextarea,.fselect{width:100%;padding:11px 14px;border:1.5px solid rgba(44,48,64,.12);border-radius:13px;font-size:.87rem;font-family:'DM Sans',sans-serif;background:#FAFCFF;color:var(--ink);outline:none;transition:all .2s;}
.finput:focus,.ftextarea:focus{border-color:var(--sky);box-shadow:0 0 0 4px rgba(137,196,217,.12);background:white;}
.ftextarea{min-height:78px;resize:vertical;line-height:1.6;padding-bottom:38px;}

/* ── VARITA ── */
.varita{position:absolute;right:10px;bottom:10px;background:linear-gradient(135deg,var(--lilac),var(--sky));color:white;border:none;border-radius:20px;padding:4px 11px;font-size:.68rem;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:4px;box-shadow:0 2px 8px rgba(184,160,204,.4);}
.varita.loading{opacity:.7;cursor:not-allowed;}

/* ── BUTTONS ── */
.btn{width:100%;padding:13px;background:var(--grad);color:white;border:none;border-radius:14px;font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;box-shadow:0 4px 16px rgba(137,196,217,.35);transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;}
.btn:hover{transform:translateY(-2px);}
.btn-pub{background:linear-gradient(135deg,var(--sage-l),var(--sky-l));color:var(--ink);box-shadow:0 4px 16px rgba(154,187,168,.3);}
.btn-sm{padding:7px 14px;font-size:.78rem;width:auto;border-radius:10px;}
.btn-ghost{background:white;color:var(--sky);border:1.5px solid var(--sky-l);box-shadow:none;}
.btn-danger{background:#fef2f2;color:#dc2626;border:1.5px solid #fecaca;box-shadow:none;}
.btn-sky{background:var(--sky);color:white;border:none;}

/* ── PACIENTES ── */
.pac-card{background:white;border:1.5px solid rgba(44,48,64,.08);border-radius:14px;padding:12px 14px;margin-bottom:8px;cursor:pointer;transition:all .22s;box-shadow:var(--shadow);}
.pac-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-lg);border-color:var(--sky-l);}
.pac-card.sel{background:linear-gradient(135deg,var(--sky-p),var(--lilac-p));border-color:var(--sky-l);}
.pac-nombre{font-size:.9rem;font-weight:700;color:var(--sky);}
.pac-info{font-size:.72rem;color:var(--ink-60);margin-top:2px;}
.pac-actions{display:flex;gap:5px;margin-top:7px;}

/* ── PLANIFICACION ── */
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;}
.stat{background:white;border-radius:12px;padding:10px;text-align:center;box-shadow:var(--shadow);}
.stat .n{font-family:'Nunito',sans-serif;font-size:1.4rem;font-weight:900;color:var(--sky);}
.stat .l{font-size:.65rem;color:var(--ink-60);margin-top:2px;}
.stat-t .n{color:var(--ink);}
.stat-p .n{color:var(--rose);}
.stat-w .n{color:var(--lilac);}
.stat-l .n{color:var(--sage);}
.prog-bar{height:8px;background:var(--sky-p);border-radius:20px;margin-bottom:14px;overflow:hidden;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--sky),var(--lilac));border-radius:20px;transition:width .4s;}
.obj-card{display:flex;align-items:center;gap:10px;background:white;border:1.5px solid rgba(44,48,64,.08);border-radius:14px;padding:12px 14px;margin-bottom:8px;cursor:pointer;transition:all .2s;box-shadow:var(--shadow);}
.obj-card:hover{border-color:var(--sky-l);}
.obj-num{width:28px;height:28px;border-radius:9px;background:var(--sky-p);color:var(--sky);font-weight:800;font-size:.8rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.obj-txt{flex:1;font-size:.85rem;color:var(--ink);}
.obj-estado{font-size:.68rem;font-weight:700;padding:3px 9px;border-radius:20px;white-space:nowrap;}
.oe-sin{background:var(--rose-p);color:var(--rose);}
.oe-trab{background:var(--lilac-p);color:var(--lilac);}
.oe-logr{background:var(--sage-p);color:var(--sage);}

/* ── RECORDATORIOS ── */
.recor-box{background:linear-gradient(135deg,var(--lilac-p),var(--sky-p));border-radius:16px;padding:14px;margin-bottom:14px;}
.recor-title{font-size:.8rem;font-weight:700;color:var(--lilac);margin-bottom:10px;}
.recor-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;}
.recor-check{width:20px;height:20px;border-radius:6px;border:2px solid var(--lilac-l);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.65rem;color:white;flex-shrink:0;transition:all .2s;}
.recor-check.done{background:var(--sage);border-color:var(--sage);}
.recor-txt{flex:1;font-size:.8rem;color:var(--ink);}
.recor-txt.done{text-decoration:line-through;color:var(--ink-30);}
.recor-del{background:none;border:none;cursor:pointer;color:var(--ink-30);font-size:.8rem;}

/* ── SESION ── */
.chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px;}
.chip{padding:6px 12px;border-radius:20px;font-size:.75rem;font-weight:600;cursor:pointer;transition:all .2s;border:1.5px solid;}
.chip-apoyo{background:var(--sky-p);color:var(--sky);border-color:var(--sky-l);}
.chip.sel{background:var(--sky);color:white;border-color:var(--sky);}
.audio-box{background:linear-gradient(135deg,var(--lilac-p),var(--rose-p));border-radius:16px;padding:14px;margin-bottom:14px;}
.audio-title{font-size:.8rem;font-weight:700;color:var(--lilac);margin-bottom:8px;}
.btn-rec{background:var(--lilac);color:white;border:none;border-radius:20px;padding:8px 18px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:700;cursor:pointer;transition:all .2s;}
.btn-rec.rec{background:#dc2626;animation:pulse 1s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.7}}
.rec-timer{font-size:.8rem;color:var(--lilac);font-weight:700;}

/* ── HISTORIAL ── */
.ses-card{background:white;border-radius:16px;margin-bottom:12px;overflow:hidden;box-shadow:var(--shadow);}
.ses-head{background:linear-gradient(135deg,var(--sky-p),var(--lilac-p));padding:12px 16px;display:flex;align-items:center;gap:10px;}
.ses-num{width:30px;height:30px;border-radius:10px;background:var(--sky);color:white;font-weight:800;font-size:.85rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.ses-fecha{font-weight:700;font-size:.9rem;color:var(--ink);}
.ses-body{padding:12px 16px;}
.ses-section{padding:8px 10px;border-radius:10px;margin-bottom:8px;font-size:.83rem;line-height:1.5;color:var(--ink);}
.ss-title{font-size:.7rem;font-weight:700;margin-bottom:4px;color:var(--sky);}
.ss-obs{background:var(--sky-p);border-left:3px solid var(--sky);}
.ss-logros{background:var(--sage-p);border-left:3px solid var(--sage);}
.ss-barr{background:var(--rose-p);border-left:3px solid var(--rose);}
.ss-tareas{background:var(--lilac-p);border-left:3px solid var(--lilac);}
.ses-btns{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:6px;padding:12px 16px;border-top:1px solid rgba(44,48,64,.06);}
.ses-btn{padding:8px;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:.72rem;font-weight:700;cursor:pointer;transition:all .2s;}
.ses-btn:hover{transform:translateY(-1px);}
.sb-wa{background:#dcfce7;color:#16a34a;}
.sb-mail{background:var(--sky-p);color:#0d6b8a;}
.sb-copy{background:#f8fafc;color:var(--ink-60);}
.sb-pdf{background:var(--rose-p);color:#9f1239;}
.sb-portal{background:linear-gradient(135deg,var(--sky-l),var(--lilac-l));color:var(--ink);grid-column:span 4;font-size:.78rem;margin-top:2px;}

/* ── MODALES ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(44,48,64,.4);backdrop-filter:blur(4px);z-index:1000;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.open{display:flex;}
.modal-box{background:white;border-radius:24px;padding:24px;width:100%;max-width:480px;box-shadow:var(--shadow-lg);max-height:90vh;overflow-y:auto;}
.modal-title{font-family:'Nunito',sans-serif;font-size:1.1rem;font-weight:900;color:var(--sky);margin-bottom:4px;}
.modal-sub{font-size:.78rem;color:var(--ink-60);margin-bottom:18px;}
.ia-ver{background:#f8fafc;border-radius:14px;padding:14px;margin-bottom:12px;border:1.5px solid rgba(44,48,64,.08);}
.ia-ver-label{font-size:.7rem;font-weight:700;color:var(--ink-60);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;}
.ia-ver-tech{background:var(--sky-p);border:1.5px solid var(--sky-l);}
.ia-ver-amena{background:var(--sage-p);border:1.5px solid var(--sage-l);}
.ia-txt{font-size:.85rem;line-height:1.6;color:var(--ink);white-space:pre-wrap;}
.modal-btns{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:16px;}
.prev-content{background:#f8fafc;border-radius:14px;padding:14px;font-size:.83rem;line-height:1.6;color:var(--ink);white-space:pre-wrap;margin-bottom:16px;max-height:200px;overflow-y:auto;}
.prev-btns{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.prev-pub{grid-column:span 2;background:linear-gradient(135deg,var(--sky-l),var(--lilac-l));color:var(--ink);border:none;border-radius:13px;padding:14px;font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;width:100%;}

/* ── CONFIG ── */
.config-item{background:white;border-radius:16px;padding:16px;margin-bottom:12px;box-shadow:var(--shadow);}
.config-label{font-size:.7rem;font-weight:700;color:var(--ink-30);text-transform:uppercase;letter-spacing:.6px;margin-bottom:12px;}

/* ── ASISTENCIA ── */
.asist-btn{padding:9px 16px;border:2px solid rgba(44,48,64,.12);border-radius:20px;background:white;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:600;color:var(--ink-60);cursor:pointer;transition:all .2s;}
.asist-btn:hover{transform:translateY(-1px);}
.asist-btn.sel-asiste{background:#dcfce7;border-color:#16a34a;color:#15803d;}
.asist-btn.sel-no{background:#fee2e2;border-color:#dc2626;color:#dc2626;}
.asist-btn.sel-cancel{background:var(--lilac-p);border-color:var(--lilac);color:var(--lilac);}

/* ── OBJETIVO CON ESTADO ── */
.obj-ses-card{background:#f8fafc;border:1.5px solid rgba(44,48,64,.08);border-radius:14px;padding:12px 14px;margin-bottom:8px;}
.obj-ses-nombre{font-size:.85rem;font-weight:600;color:var(--ink);margin-bottom:8px;}
.logro-btns{display:flex;gap:6px;flex-wrap:wrap;}
.logro-btn{padding:5px 12px;border-radius:20px;border:1.5px solid;font-family:'DM Sans',sans-serif;font-size:.72rem;font-weight:700;cursor:pointer;background:white;transition:all .2s;}
.logro-btn:hover{transform:translateY(-1px);}
.lb-logrado{color:#15803d;border-color:#86efac;}
.lb-logrado.sel{background:#dcfce7;border-color:#16a34a;}
.lb-apoyo{color:#0369a1;border-color:#7dd3fc;}
.lb-apoyo.sel{background:#e0f2fe;border-color:#0ea5e9;}
.lb-parcial{color:#b45309;border-color:#fcd34d;}
.lb-parcial.sel{background:#fef9c3;border-color:#f59e0b;}
.lb-no{color:#dc2626;border-color:#fca5a5;}
.lb-no.sel{background:#fee2e2;border-color:#dc2626;}
.obj-ses-del{background:none;border:none;cursor:pointer;color:var(--ink-30);font-size:.8rem;float:right;}
.empty{text-align:center;padding:32px 16px;color:var(--ink-30);}
.ei{font-size:2rem;margin-bottom:8px;}

/* ── BUSCAR ── */
.search-box{background:white;border:1.5px solid rgba(44,48,64,.08);border-radius:14px;padding:10px 14px;width:100%;font-family:'DM Sans',sans-serif;font-size:.85rem;outline:none;margin-bottom:12px;color:var(--ink);}
.search-box:focus{border-color:var(--sky);}

/* ── RESPONSIVE ── */
@media(max-width:700px){
  .app-body{grid-template-columns:1fr;}
  .sidebar{border-right:none;border-bottom:1px solid rgba(44,48,64,.07);padding:12px;}
  .ses-btns{grid-template-columns:1fr 1fr;}
  .sb-portal{grid-column:span 2;}
}

/* ── ANAMNESIS ── */
.ana-toggle{width:100%;display:flex;align-items:center;justify-content:space-between;padding:11px 14px;border:1.5px dashed var(--sky-l);border-radius:13px;background:var(--sky-p);cursor:pointer;margin:12px 0 0;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:700;color:var(--sky);transition:background .2s;}
.ana-toggle:hover{background:var(--lilac-p);border-color:var(--lilac-l);color:var(--lilac);}
.ana-arrow{font-size:.7rem;transition:transform .25s;color:var(--sky);}
.ana-arrow.open{transform:rotate(180deg);}
.ana-body{display:none;margin-top:10px;padding:14px;background:var(--sky-p);border-radius:13px;border:1.5px solid var(--sky-l);}
.ana-body.open{display:block;}
.ana-sec-title{font-size:.65rem;font-weight:700;color:var(--ink-30);text-transform:uppercase;letter-spacing:.6px;margin:12px 0 7px;padding-bottom:4px;border-bottom:1px solid var(--sky-l);}
.ana-sec-title:first-child{margin-top:0;}
.ana-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:4px;}
.ana-grid.full{grid-template-columns:1fr;}
.ana-fgroup{display:flex;flex-direction:column;gap:3px;}
.ana-label{font-size:.7rem;font-weight:700;color:var(--sky);text-transform:uppercase;letter-spacing:.3px;}
.ana-select,.ana-input,.ana-textarea{width:100%;padding:8px 10px;border:1.5px solid rgba(44,48,64,.12);border-radius:10px;font-size:.82rem;font-family:'DM Sans',sans-serif;background:white;color:var(--ink);outline:none;transition:border .2s;}
.ana-select:focus,.ana-input:focus,.ana-textarea:focus{border-color:var(--sky);}
.ana-textarea{min-height:56px;resize:vertical;}
.chip-row{display:flex;flex-wrap:wrap;gap:5px;margin-top:2px;}
.achip input{display:none;}
.achip label{padding:4px 10px;border-radius:20px;border:1.5px solid var(--sky-l);font-size:.72rem;cursor:pointer;background:white;color:var(--ink-60);transition:all .15s;white-space:nowrap;}
.achip input:checked+label{background:var(--sky);border-color:var(--sky);color:white;font-weight:700;}
.werni-hint{margin-top:10px;padding:7px 11px;background:rgba(184,160,204,.15);border-left:3px solid var(--lilac);border-radius:0 9px 9px 0;font-size:.72rem;color:var(--lilac);display:none;}
.werni-hint.show{display:block;}
</style>
</head>
<body>

<!-- ══ LOGIN ══ -->
<div id="screen-login" class="screen active">
<div class="login-wrap">
<div class="login-card">
  <div class="login-logo">
    <img src="data:image/png;base64," id="logo-img" alt="Fono Aprende" style="width:160px;height:auto;" onerror="this.style.display='none';document.getElementById('logo-fallback').style.display='block'">
    <div id="logo-fallback" style="display:none;font-family:'Nunito',sans-serif;font-size:1.6rem;font-weight:900;color:var(--sky);margin-bottom:6px;">Fono Aprende</div>
    <div class="app-name">Sesión en un Click</div>
    <div class="sub">Registro clínico inteligente</div>
  </div>
  <div class="login-tabs">
    <button class="login-tab active" onclick="switchLoginTab('login',this)">Iniciar sesión</button>
    <button class="login-tab" onclick="switchLoginTab('registro',this)">Crear cuenta</button>
  </div>
  <div id="tab-login">
    <div class="fld"><label>Email</label><input type="email" id="login-email" placeholder="tu@email.com"></div>
    <div class="fld"><label>Contraseña</label><input type="password" id="login-pass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <button class="btn-enter" id="btn-login" onclick="doLogin()">Entrar →</button>
  </div>
  <div id="tab-registro" style="display:none;">
    <div class="fld"><label>Email</label><input type="email" id="reg-email" placeholder="tu@email.com"></div>
    <div class="fld"><label>Contraseña (mínimo 6 caracteres)</label><input type="password" id="reg-pass" placeholder="••••••••"></div>
    <button class="btn-enter" id="btn-reg" onclick="doRegistro()">Crear cuenta →</button>
  </div>
  <div id="login-msg" class="login-err"></div>
</div>
</div>
</div>

<!-- ══ APP ══ -->
<div id="screen-app" class="screen">

  <!-- HEADER -->
  <div class="app-header">
    <div class="app-header-inner">
      <div class="h-left">
        <div class="header-pac" id="header-pac" onclick="switchVista('pacientes')">👤 Sin paciente</div>
      </div>
      <div class="h-center">
        <div class="h-title">📋 Sesión en un Click</div>
        <div class="h-sub">Fono Aprende · Registro clínico</div>
      </div>
      <div class="h-right">
        <div class="save-pill"><div class="save-dot" id="save-dot"></div><span id="save-txt">Cargando</span></div>
        <span class="ubadge" id="user-email-badge"></span>
        <button class="btn-logout" onclick="doLogout()">Salir</button>
      </div>
    </div>
  </div>

  <!-- TABS -->
  <div class="main-tabs">
    <button class="mtab active" onclick="switchVista('pacientes',this)">👥 Pacientes</button>
    <button class="mtab" onclick="switchVista('planificacion',this)">🎯 Planificación</button>
    <button class="mtab" onclick="switchVista('sesion',this)">📝 Sesión</button>
    <button class="mtab" onclick="switchVista('historial',this)">📅 Historial</button>
    <button class="mtab" onclick="switchVista('asha',this)">📚 ASHA</button>
    <button class="mtab" onclick="switchVista('config',this)">⚙️ Config</button>  </div>

  <!-- BODY -->
  <div class="app-body">

    <!-- SIDEBAR: lista pacientes siempre visible -->
    <div class="sidebar">
      <div class="sidebar-title">Mis Pacientes</div>
      <input class="search-box" placeholder="🔍 Buscar paciente…" oninput="filtrarPacientes(this.value)">
      <div id="lista-pacientes"><div class="empty"><div class="ei">👥</div><p>Sin pacientes</p></div></div>
    </div>

    <!-- CONTENIDO PRINCIPAL -->
    <div class="main-content">

      <!-- VISTA PACIENTES: formulario agregar -->
      <div id="vista-pacientes" class="vista active">
        <div class="card">
          <div class="card-title">➕ Nuevo Paciente</div>
          <div class="fgroup"><label class="flabel">Nombre *</label><input class="finput" id="np-nombre" placeholder="Nombre completo"></div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div class="fgroup"><label class="flabel">Teléfono</label><input class="finput" id="np-tel" placeholder="+56912345678"></div>
            <div class="fgroup"><label class="flabel">Email</label><input class="finput" id="np-email" placeholder="familia@email.com"></div>
            <div class="fgroup"><label class="flabel">Fecha nacimiento</label><input class="finput" type="date" id="np-nac"></div>
            <div class="fgroup"><label class="flabel">Diagnóstico</label><input class="finput" id="np-diag" placeholder="TDL, TEA…"></div>
          </div>

          <!-- ANAMNESIS COLAPSABLE -->
          <button class="ana-toggle" type="button" onclick="toggleAnamnesis()">
            <span>📋 Agregar antecedentes clínicos (Anamnesis)</span>
            <span class="ana-arrow" id="ana-arrow">▼</span>
          </button>

          <div class="ana-body" id="ana-body">

            <div class="ana-sec-title">🤱 Perinatal</div>
            <div class="ana-grid">
              <div class="ana-fgroup">
                <span class="ana-label">Parto</span>
                <select class="ana-select" id="ana-parto">
                  <option value="">— Selecciona —</option>
                  <option>Vaginal</option><option>Cesárea</option><option>Fórceps</option>
                </select>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Gestación</span>
                <select class="ana-select" id="ana-gest">
                  <option value="">— Selecciona —</option>
                  <option>Término</option><option>Pretérmino</option><option>Postérmino</option>
                </select>
              </div>
            </div>
            <div class="ana-grid full" style="margin-top:6px;">
              <div class="ana-fgroup">
                <span class="ana-label">Observaciones perinatales</span>
                <textarea class="ana-textarea" id="ana-peri-obs" placeholder="Ictericia, UCIN, APGAR…"></textarea>
              </div>
            </div>

            <div class="ana-sec-title">🏃 Desarrollo motor</div>
            <div class="ana-grid">
              <div class="ana-fgroup">
                <span class="ana-label">Marcha independiente</span>
                <select class="ana-select" id="ana-marcha">
                  <option value="">— Selecciona —</option>
                  <option>Normal (12-15m)</option><option>Tardía (16-18m)</option><option>Muy tardía (&gt;18m)</option>
                </select>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Hipotonía</span>
                <div class="chip-row" style="margin-top:6px;">
                  <div class="achip"><input type="radio" name="ana-hip" id="ah1" value="No"><label for="ah1">No</label></div>
                  <div class="achip"><input type="radio" name="ana-hip" id="ah2" value="Sí"><label for="ah2">Sí</label></div>
                  <div class="achip"><input type="radio" name="ana-hip" id="ah3" value="Sospecha"><label for="ah3">Sospecha</label></div>
                </div>
              </div>
            </div>
            <div class="ana-fgroup" style="margin-top:6px;">
              <span class="ana-label">Gateo</span>
              <div class="chip-row">
                <div class="achip"><input type="radio" name="ana-gateo" id="ag1" value="Sí gateó"><label for="ag1">Sí gateó</label></div>
                <div class="achip"><input type="radio" name="ana-gateo" id="ag2" value="No gateó"><label for="ag2">No gateó</label></div>
              </div>
            </div>

            <div class="ana-sec-title">💬 Comunicación y lenguaje</div>
            <div class="ana-grid">
              <div class="ana-fgroup">
                <span class="ana-label">Primeras palabras</span>
                <select class="ana-select" id="ana-pp">
                  <option value="">— Selecciona —</option>
                  <option>Normal (10-15m)</option><option>Tardías (16-18m)</option><option>Muy tardías (&gt;18m)</option>
                </select>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Frases 2 palabras</span>
                <select class="ana-select" id="ana-frases">
                  <option value="">— Selecciona —</option>
                  <option>Normal (18-24m)</option><option>Tardías (25-30m)</option><option>Muy tardías (&gt;30m)</option>
                </select>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Comprensión</span>
                <div class="chip-row" style="margin-top:6px;">
                  <div class="achip"><input type="radio" name="ana-comp" id="ac1" value="Normal"><label for="ac1">Normal</label></div>
                  <div class="achip"><input type="radio" name="ana-comp" id="ac2" value="Reducida"><label for="ac2">Reducida</label></div>
                </div>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Inteligibilidad estimada</span>
                <select class="ana-select" id="ana-intel">
                  <option value="">— Selecciona —</option>
                  <option>&lt;25%</option><option>25-50%</option><option>50-75%</option><option>&gt;75%</option>
                </select>
              </div>
            </div>
            <div class="ana-fgroup" style="margin-top:6px;">
              <span class="ana-label">Juego simbólico</span>
              <div class="chip-row">
                <div class="achip"><input type="radio" name="ana-juego" id="aj1" value="Presente"><label for="aj1">Presente</label></div>
                <div class="achip"><input type="radio" name="ana-juego" id="aj2" value="Ausente"><label for="aj2">Ausente</label></div>
                <div class="achip"><input type="radio" name="ana-juego" id="aj3" value="Reducido"><label for="aj3">Reducido</label></div>
              </div>
            </div>

            <div class="ana-sec-title">👄 Motricidad orofacial (MOF)</div>
            <div class="ana-grid">
              <div class="ana-fgroup">
                <span class="ana-label">Respiración</span>
                <div class="chip-row" style="margin-top:6px;">
                  <div class="achip"><input type="radio" name="ana-resp" id="ar1" value="Nasal"><label for="ar1">Nasal</label></div>
                  <div class="achip"><input type="radio" name="ana-resp" id="ar2" value="Oral"><label for="ar2">Oral</label></div>
                  <div class="achip"><input type="radio" name="ana-resp" id="ar3" value="Mixta"><label for="ar3">Mixta</label></div>
                </div>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Mordida</span>
                <select class="ana-select" id="ana-mordida">
                  <option value="">— Selecciona —</option>
                  <option>Normal</option><option>Abierta anterior</option><option>Cruzada</option><option>Profunda</option>
                </select>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Reposo lingual</span>
                <select class="ana-select" id="ana-lengua">
                  <option value="">— Selecciona —</option>
                  <option>Normal (paladar)</option><option>Bajo (suelo boca)</option><option>Interdental</option>
                </select>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Alimentación</span>
                <select class="ana-select" id="ana-ali">
                  <option value="">— Selecciona —</option>
                  <option>Normal</option><option>Selectiva</option><option>Dificultad masticación</option>
                </select>
              </div>
            </div>

            <div class="ana-sec-title">🏥 Antecedentes médicos</div>
            <div class="ana-grid">
              <div class="ana-fgroup">
                <span class="ana-label">Audición</span>
                <select class="ana-select" id="ana-audio">
                  <option value="">— Selecciona —</option>
                  <option>Normal evaluada</option><option>Normal no evaluada</option><option>Hipoacusia</option><option>Pendiente</option>
                </select>
              </div>
              <div class="ana-fgroup">
                <span class="ana-label">Antec. familiares fono</span>
                <div class="chip-row" style="margin-top:6px;">
                  <div class="achip"><input type="radio" name="ana-fam" id="af1" value="Sí"><label for="af1">Sí</label></div>
                  <div class="achip"><input type="radio" name="ana-fam" id="af2" value="No"><label for="af2">No</label></div>
                  <div class="achip"><input type="radio" name="ana-fam" id="af3" value="Desconoce"><label for="af3">Desconoce</label></div>
                </div>
              </div>
            </div>

            <div class="ana-grid full" style="margin-top:6px;">
              <div class="ana-fgroup">
                <span class="ana-label">Motivo de consulta / observaciones generales</span>
                <textarea class="ana-textarea" id="ana-motivo" placeholder="Lo que la familia reporta, preocupaciones…"></textarea>
              </div>
            </div>

            <div class="werni-hint" id="werni-ana-hint">
              🧠 Werni analizará estos datos cuando abras la sesión de este paciente
            </div>
          </div>
          <!-- FIN ANAMNESIS -->

          <button class="btn" style="margin-top:14px;" onclick="agregarPaciente()">+ Agregar Paciente</button>
        </div>
        <div class="empty" style="padding:20px;"><p style="font-size:.82rem;color:var(--ink-30);">← Selecciona un paciente para comenzar</p></div>
      </div>

      <!-- VISTA PLANIFICACION -->
      <div id="vista-planificacion" class="vista">
        <div class="card">
          <div style="font-size:.75rem;color:var(--ink-60);margin-bottom:2px;">Planificación de</div>
          <div style="font-family:'Nunito',sans-serif;font-size:1.1rem;font-weight:800;color:var(--sky);" id="plan-nombre">—</div>
        </div>
        <div id="recor-box" class="recor-box" style="display:none;">
          <div class="recor-title">📌 Recordatorios · <span id="recor-pac"></span></div>
          <div style="display:flex;gap:7px;margin-bottom:8px;">
            <input class="finput" id="recor-input" placeholder="Agregar recordatorio…" style="flex:1;padding:8px 12px;">
            <button onclick="agregarRecordatorio()" style="background:var(--lilac);color:white;border:none;border-radius:10px;padding:8px 14px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">+</button>
          </div>
          <div id="recor-lista"></div>
        </div>
        <div class="stat-row" id="plan-stats">
          <div class="stat stat-t"><div class="n">0</div><div class="l">Total</div></div>
          <div class="stat stat-p"><div class="n">0</div><div class="l">Sin iniciar</div></div>
          <div class="stat stat-w"><div class="n">0</div><div class="l">En proceso</div></div>
          <div class="stat stat-l"><div class="n">0</div><div class="l">Logrado</div></div>
        </div>
        <div class="prog-bar"><div class="prog-fill" id="prog-fill" style="width:0%"></div></div>
        <button class="btn btn-ghost" onclick="agregarObjetivo()" style="margin-bottom:14px;">+ Agregar objetivo terapéutico</button>
        <div id="lista-objetivos"><div class="empty"><div class="ei">🎯</div><p>Selecciona un paciente</p></div></div>
      </div>

      <!-- VISTA SESION -->
      <div id="vista-sesion" class="vista">
        <div style="background:var(--grad);border-radius:16px;padding:14px 16px;margin-bottom:14px;display:flex;align-items:center;gap:10px;">
          <span style="font-size:1.4rem;">📝</span>
          <div>
            <div style="font-weight:700;color:var(--ink);" id="ses-pac-nombre">Selecciona un paciente</div>
            <div style="font-size:.72rem;color:var(--ink-60);" id="ses-fecha"></div>
          </div>
        </div>

        <!-- ASISTENCIA -->
        <div class="card" style="margin-bottom:12px;">
          <div class="card-title">📋 Asistencia</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button class="asist-btn" id="asist-asiste" onclick="setAsistencia('asiste')">✅ Asiste</button>
            <button class="asist-btn" id="asist-no" onclick="setAsistencia('no_asiste')">❌ No asiste</button>
            <button class="asist-btn" id="asist-cancel" onclick="setAsistencia('cancelada')">🚫 Sesión cancelada</button>
          </div>
        </div>

        <!-- OBJETIVOS -->
        <div class="card">
          <div class="card-title">🎯 Objetivos trabajados hoy</div>
          <div style="display:flex;gap:7px;margin-bottom:10px;">
            <input class="finput" id="obj-nuevo" placeholder="Escribe un objetivo y presiona +" style="flex:1;padding:9px 12px;" onkeydown="if(event.key==='Enter')agregarChipPersonalizado()">
            <button onclick="agregarChipPersonalizado()" style="background:var(--sky);color:white;border:none;border-radius:10px;padding:9px 18px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:1.1rem;">+</button>
          </div>
          <div style="margin-bottom:8px;">
            <span style="font-size:.72rem;color:var(--ink-30);">O carga desde planificación: </span>
            <a href="#" onclick="mostrarSugeridos();return false;" style="font-size:.72rem;color:var(--sky);">ver objetivos del paciente ▾</a>
          </div>
          <div id="chips-obj-sugeridos" style="display:none;flex-wrap:wrap;gap:6px;margin-bottom:12px;padding:10px;background:var(--sky-p);border-radius:12px;"></div>
          <!-- Objetivos seleccionados con estado -->
          <div id="obj-seleccionados"></div>
        </div>

        <div class="card">
          <div class="fgroup">
            <label class="flabel">✨ Logros</label>
            <textarea class="ftextarea" id="ses-logros" placeholder="¿Qué logró el paciente hoy?" oninput="autosave()"></textarea>
            <button class="varita" onclick="mejorarIA('ses-logros','logros de sesión')">✨ Mejorar</button>
          </div>
          <div class="fgroup">
            <label class="flabel">💬 Observaciones clínicas</label>
            <textarea class="ftextarea" id="ses-obs" placeholder="Conducta, respuesta al tratamiento…" oninput="autosave()"></textarea>
            <button class="varita" onclick="mejorarIA('ses-obs','observaciones clínicas')">✨ Mejorar</button>
          </div>
          <div class="fgroup">
            <label class="flabel">⚠️ Barreras y facilitadores</label>
            <textarea class="ftextarea" id="ses-barr" placeholder="Factores que dificultaron o facilitaron la sesión…" oninput="autosave()"></textarea>
            <button class="varita" onclick="mejorarIA('ses-barr','barreras y facilitadores')">✨ Mejorar</button>
          </div>
          <div class="fgroup">
            <label class="flabel">🏠 Tarea para el hogar</label>
            <textarea class="ftextarea" id="ses-tareas" placeholder="Actividades de refuerzo en casa…" oninput="autosave()"></textarea>
            <button class="varita" onclick="mejorarIA('ses-tareas','tareas para el hogar')">✨ Mejorar</button>
          </div>
        </div>
        <div class="audio-box">
          <div class="audio-title">🎙️ Nota de voz <span style="font-weight:400;opacity:.7;">(máx 10 seg · los papás la escuchan en el portal)</span></div>
          <div style="display:flex;align-items:center;gap:10px;">
            <button class="btn-rec" id="btn-rec" onclick="toggleGrabacion()">🎙️ Grabar</button>
            <span class="rec-timer" id="rec-timer" style="display:none">0:00</span>
          </div>
          <div id="audio-player" style="margin-top:8px;display:none;"></div>
        </div>
        <div style="display:flex;gap:10px;margin-top:4px;">
          <button class="btn" style="flex:2;" onclick="guardarSesion()">💾 Finalizar y Guardar</button>
          <button class="btn btn-pub" style="flex:1;" onclick="abrirPreview()">🏡 Publicar en Portal</button>
        </div>
      </div>

      <!-- VISTA HISTORIAL -->
      <div id="vista-historial" class="vista">
        <div id="hist-portal-btn" style="display:none;margin-bottom:14px;">
          <button class="btn btn-pub" onclick="verPortalComoPadre()">🏡 Ver Portal como lo ve la familia →</button>
        </div>
        <div id="lista-historial"><div class="empty"><div class="ei">📅</div><p>Selecciona un paciente</p></div></div>
      </div>

      <!-- VISTA ASHA -->
      <div id="vista-asha" class="vista">
        <div class="card">
          <div class="card-title">📚 Actualizaciones ASHA</div>
          <p style="font-size:.82rem;color:var(--ink-60);margin-bottom:14px;">Artículos y evidencia reciente de fonoaudiología infantil.</p>
          <div id="asha-lista"><div class="empty"><div class="ei">📚</div><p>Cargando artículos…</p></div></div>
        </div>
      </div>

      <!-- VISTA CONFIG -->
      <div id="vista-config" class="vista">
        <div class="config-item">
          <div class="config-label">Datos profesionales</div>
          <div class="fgroup"><label class="flabel">Nombre completo</label><input class="finput" id="cfg-nombre" placeholder="Constanza Sabra"></div>
          <div class="fgroup"><label class="flabel">Título</label><input class="finput" id="cfg-titulo" placeholder="Fonoaudióloga"></div>
          <div class="fgroup"><label class="flabel">N° Registro</label><input class="finput" id="cfg-registro"></div>
          <button class="btn" onclick="guardarConfig()">Guardar datos</button>
        </div>
        <div class="config-item">
          <div class="config-label">API Key Anthropic (IA ✨)</div>
          <div class="fgroup"><input class="finput" id="cfg-apikey" type="password" placeholder="sk-ant-api03-…"></div>
          <button class="btn btn-ghost" onclick="guardarAPIKey()">Guardar API Key</button>
          <p style="font-size:.72rem;color:var(--ink-30);margin-top:8px;">Se guarda solo en este navegador. Necesaria para la varita ✨</p>
        </div>
      </div>

    </div><!-- /main-content -->
  </div><!-- /app-body -->
</div><!-- /screen-app -->

<!-- ══ MODAL IA ══ -->
<div class="modal-overlay" id="modal-ia">
  <div class="modal-box">
    <div class="modal-title">✨ Versiones generadas por IA</div>
    <div class="modal-sub">Elige cuál usar o cierra para editar manualmente</div>
    <div class="ia-ver ia-ver-tech">
      <div class="ia-ver-label">🔬 Registro técnico (clínico)</div>
      <div class="ia-txt" id="ia-tech-txt"></div>
    </div>
    <div class="ia-ver ia-ver-amena">
      <div class="ia-ver-label">🏡 Resumen familiar (para papás)</div>
      <div class="ia-txt" id="ia-amena-txt"></div>
    </div>
    <div class="modal-btns">
