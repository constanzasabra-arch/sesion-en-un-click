// AUDIO
async function toggleGrabacion() {
    if (isRec) { detenerGrabacion(); return; }
    try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio:true });
        mediaRecorder=new MediaRecorder(stream); audioChunks=[]; isRec=true; recSecs=0;
        const btn=document.getElementById('btn-rec'); const timer=document.getElementById('rec-timer');
        btn.textContent='⏹ Detener'; btn.classList.add('rec'); timer.style.display='inline';
        recInterval=setInterval(()=>{recSecs++; timer.textContent='0:'+(recSecs<10?'0':'')+recSecs; if(recSecs>=10) detenerGrabacion();},1000);
        mediaRecorder.ondataavailable=e=>audioChunks.push(e.data);
        mediaRecorder.onstop=()=>{
            audioBlob=new Blob(audioChunks,{type:'audio/webm'});
            const url=URL.createObjectURL(audioBlob);
            const player=document.getElementById('audio-player'); player.style.display='block';
            player.innerHTML='<audio controls src="'+url+'" style="width:100%;height:36px;margin-top:4px;"></audio>';
            stream.getTracks().forEach(t=>t.stop());
        };
        mediaRecorder.start();
    } catch(e) { alert('No se pudo acceder al micrófono: '+e.message); }
}
function detenerGrabacion() {
    clearInterval(recInterval); isRec=false;
    if (mediaRecorder&&mediaRecorder.state!=='inactive') mediaRecorder.stop();
    const btn=document.getElementById('btn-rec'); btn.textContent='🎙️ Grabar'; btn.classList.remove('rec');
    document.getElementById('rec-timer').style.display='none';
}

// IA
async function mejorarIA(campoId, tipo) {
    const el=document.getElementById(campoId); if(!el||!el.value.trim()){alert('Escribe algo primero');return;}
    iaCurrentField=campoId;
    const btn=el.parentElement.querySelector('.varita');
    if(btn){btn.classList.add('loading');btn.textContent='…';}
    try {
        const resp=await fetch('/.netlify/functions/werni',{
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({
                tipo,
                mensaje:'Campo: '+tipo+'. Texto crudo de la fono: "'+el.value.trim()+'". Genera 2 versiones MUY CORTAS (máximo 2 líneas cada una). Responde SOLO:\nTECNICA: [terminología fonoaudiológica precisa, sin explicar]\nAMENA: [cálido, directo, para papás, sin tecnicismos]',
                systemPrompt:'Eres Werni, asistente clínica fonoaudiológica experta en metodología Susanibar y desarrollo infantil. Respondes de forma breve, precisa y cálida.'
            })
        });
        const d=await resp.json();
        if(d.error) throw new Error(d.error);
        const txt=d.respuesta;
        const tech=txt.split('AMENA:')[0].replace(/TECNICA:|TÉCNICA:/i,'').trim();
        const amena=txt.includes('AMENA:')?txt.split('AMENA:')[1].trim():'';
        document.getElementById('ia-tech-txt').textContent=tech;
        document.getElementById('ia-amena-txt').textContent=amena;
        document.getElementById('modal-ia').classList.add('open');
    } catch(e) { alert('Error Werni: '+e.message); }
    finally { if(btn){btn.classList.remove('loading');btn.textContent='✨ Mejorar';} }
}
